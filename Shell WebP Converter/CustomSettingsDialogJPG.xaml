<Window x:Class="Shell_WebP_Converter.CustomSettingsDialogJPG"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shell_WebP_Converter"
        xmlns:converters="clr-namespace:Shell_WebP_Converter.Converters"
        xmlns:properties="clr-namespace:Shell_WebP_Converter.Resources"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.CustomSettings}" Height="Auto" MinHeight="100" Width="Auto"  ResizeMode="NoResize" WindowStartupLocation="CenterScreen" WindowState="Normal" SizeToContent="WidthAndHeight" Style="{DynamicResource WindowStyle}" Loaded="Window_Loaded">
    <Window.Resources>
        <converters:InvertBooleanConverter x:Key="InvertBooleanConverter"/>
    </Window.Resources>
    <Grid HorizontalAlignment="Stretch">
        <StackPanel Orientation="Vertical" Margin="0,0,4,2">
            <RadioButton x:Name="CustomQualitySettingsRadioButton" IsChecked="{Binding UseCustomQualitySettings, Mode=TwoWay}" Content="{x:Static properties:Resources.CustomConversionSettings}" Checked="CustomSettingsRadioButtonChecked" Margin="2,2,0,2"/>
            <RadioButton x:Name="CompressToThresholdRadioButton" IsChecked="{Binding UseCustomQualitySettings, Converter={StaticResource InvertBooleanConverter}, Mode=TwoWay}" Content="{x:Static properties:Resources.CompressToThreshold}" Checked="CompressToThresholdRadioButtonChecked" Margin="2,2,0,0"/>
            <StackPanel  x:Name="CustomSettingsPanel" Margin="0,2,0,2">
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <Label Content="{x:Static properties:Resources.Quality}" Margin="0,-4,0,-4"/>
                    <TextBox x:Name="QualityTextBox" Text="{Binding Quality, UpdateSourceTrigger=PropertyChanged}" Width="40" VerticalContentAlignment="Center" PreviewTextInput="QualityTextBox_PreviewTextInput" PreviewKeyDown="QualityTextBox_PreviewKeyDown" MaxLength="3"/>
                    <Label Content="%" Margin="0,-3,0,-3"></Label>
                </StackPanel>
            </StackPanel>
            <StackPanel Margin="0,0,2,0">
                <StackPanel x:Name="CompressionThresholdPanel" Orientation="Vertical" Visibility="Visible" Margin="0,2,0,2">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="{x:Static properties:Resources.CompressTo}" Margin="0,-2,0,-3"></Label>
                        <TextBox x:Name="CompressionSizeThresholdTextBox" VerticalContentAlignment="Center" Margin="0,0,3,0" Width="48" Text="{Binding CompressionSizeThreshold, UpdateSourceTrigger=LostFocus}" MaxLength="7" PreviewTextInput="CompressionThresholdTextBox_PreviewTextInput" PreviewKeyDown="CompressionThresholdTextBox_PreviewKeyDown"/>
                        <ComboBox x:Name="SizeMeasurmentUnitComboBox" Margin="0,0,0,0" HorizontalAlignment="Left" Width="Auto" SelectedIndex="{Binding SizeMeasurementUnit}">
                            <ComboBoxItem Content="{x:Static properties:Resources.KiB}"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.MiB}" />
                        </ComboBox>
                    </StackPanel>
                    <CheckBox x:Name="LowerTheResolutionWhenNecessaryCheckbox" IsChecked="{Binding LowerTheResolutionWhenNecessary, Mode=TwoWay}" Content="{x:Static properties:Resources.LowerTheResolutionWhenNecessary}" Margin="1,2,0,2"/>
                </StackPanel>
                <CheckBox x:Name="DeleteOriginalFileCheckbox" IsChecked="{Binding DeleteOriginalFile, Mode=TwoWay}" Content="{x:Static properties:Resources.DeleteOriginalFile}" Margin="1,0,0,3"></CheckBox>
                <StackPanel Orientation="Horizontal">
                    <Label Content="{x:Static properties:Resources.PostfixColon}" Margin="-2,-3,0,-3"></Label>
                    <TextBox x:Name="PostfixTextBox" Text="{Binding Postfix, UpdateSourceTrigger=PropertyChanged}" Width="120" MaxLength="128"></TextBox>
                </StackPanel>
            </StackPanel>
            <Separator Opacity="0.75" Margin="2,2,2,2"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                <Button x:Name="CancelButton" Content="{x:Static properties:Resources.Cancel}" Click="CancelButton_Click" Margin="0,0,4,0"/>
                <Button x:Name="OKButton" Content="{x:Static properties:Resources.OK}" MinWidth="40"  Click="OKButton_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
