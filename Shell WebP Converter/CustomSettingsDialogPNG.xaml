<Window x:Class="Shell_WebP_Converter.CustomSettingsDialogPNG"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shell_WebP_Converter"
        xmlns:properties="clr-namespace:Shell_WebP_Converter.Resources"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.CustomSettings}" Height="Auto" MinHeight="100" Width="Auto"  ResizeMode="NoResize" WindowStartupLocation="CenterScreen" WindowState="Normal" SizeToContent="WidthAndHeight" Style="{DynamicResource WindowStyle}" Loaded="Window_Loaded">
    <Grid HorizontalAlignment="Stretch">
        <StackPanel Orientation="Vertical" Margin="0,0,4,2">
            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                <Label Content="{x:Static properties:Resources.CompressionLevelColon}" Margin="0,-3,0,-3"></Label>
                <ComboBox x:Name="CompressionComboBox" Margin="0,2,0,0" HorizontalAlignment="Left" Width="35" SelectedIndex="{Binding Compression}">
                    <ComboBoxItem Content="0"/>
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="2"/>
                    <ComboBoxItem Content="3"/>
                    <ComboBoxItem Content="4"/>
                    <ComboBoxItem Content="5"/>
                    <ComboBoxItem Content="6"/>
                    <ComboBoxItem Content="7"/>
                    <ComboBoxItem Content="8"/>
                    <ComboBoxItem Content="9"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                <Label Content="{x:Static properties:Resources.FilterColon}" Margin="0,-3,0,-3"></Label>
                <ComboBox x:Name="FilterComboBox" Margin="0,2,0,0" HorizontalAlignment="Left" Width="35" SelectedIndex="{Binding Filter}">
                    <ComboBoxItem Content="0"/>
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="2"/>
                    <ComboBoxItem Content="3"/>
                    <ComboBoxItem Content="4"/>
                    <ComboBoxItem Content="5"/>
                </ComboBox>
            </StackPanel>
            <CheckBox x:Name="DeleteOriginalFileCheckbox" IsChecked="{Binding DeleteOriginalFile, Mode=TwoWay}" Content="{x:Static properties:Resources.DeleteOriginalFile}" Margin="1,2,0,3"></CheckBox>
            <StackPanel Orientation="Horizontal">
                <Label Content="{x:Static properties:Resources.PostfixColon}" Margin="-2,-3,0,-3"></Label>
                <TextBox x:Name="PostfixTextBox" Text="{Binding Postfix, UpdateSourceTrigger=PropertyChanged}" Width="120" MaxLength="128"></TextBox>
            </StackPanel>
            <Separator Opacity="0.75" Margin="2,2,2,2"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                <Button x:Name="CancelButton" Content="{x:Static properties:Resources.Cancel}" Click="CancelButton_Click" Margin="0,0,4,0"/>
                <Button x:Name="OKButton" Content="{x:Static properties:Resources.OK}" MinWidth="40"  Click="OKButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
