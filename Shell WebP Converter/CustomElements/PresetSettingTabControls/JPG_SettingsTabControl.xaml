<UserControl x:Class="Shell_WebP_Converter.CustomElements.PresetSettingTabControls.JPG_SettingsTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:properties="clr-namespace:Shell_WebP_Converter.Resources"
             mc:Ignorable="d" 
             >
    <TabControl x:Name="SettingsTabControl" SelectedIndex="0" Grid.Column="1" VerticalAlignment="Center" Height="20" Margin="1,0,0,0">
        <TabControl.Template>
            <ControlTemplate TargetType="TabControl">
                <ContentPresenter ContentSource="SelectedContent" />
            </ControlTemplate>
        </TabControl.Template>
        <TabItem>
            <StackPanel Orientation="Horizontal">
                <TextBox Name="QualitySettingTextBox" ToolTip="{x:Static properties:Resources.QualityTooltip}" PreviewTextInput="QualitySettingTextBox_PreviewTextInput" Margin="0,0,2,0" MinWidth="38" Height="20"></TextBox>
            </StackPanel>
        </TabItem>
        <TabItem>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="CompressionSizeThresholdTextBox" ToolTip="{x:Static properties:Resources.DesiredFileSize}" MaxLength="7" PreviewTextInput="CompressionThresholdTextBox_PreviewTextInput" Margin="0,0,2,0" VerticalContentAlignment="Center" Height="20" Width="38" Text="" PreviewKeyDown="CompressionThresholdTextBox_PreviewKeyDown"/>
                <ComboBox x:Name="SizeMeasurmentUnitComboBox" HorizontalAlignment="Left" Width="50" Margin="0,0,2,0" SelectedIndex="1" Height="20" Padding="3,2,5,3">
                    <ComboBoxItem Content="{x:Static properties:Resources.KiB}"/>
                    <ComboBoxItem Content="{x:Static properties:Resources.MiB}" />
                </ComboBox>
            </StackPanel>
        </TabItem>
            <TabItem HorizontalAlignment="Center" >
            <Label Content="——X——" HorizontalContentAlignment="Center" HorizontalAlignment="Stretch" FontSize="12" Margin="0,-4,0,0"/>
        </TabItem>
        <TabItem>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="SSIM_SettingTextBox" ToolTip="{x:Static properties:Resources.SSIM_Tooltip}" MaxLength="7" PreviewTextInput="CompressionThresholdTextBox_PreviewTextInput" Margin="0,0,2,0" VerticalContentAlignment="Center" Height="20" Width="38" Text="" PreviewKeyDown="CompressionThresholdTextBox_PreviewKeyDown"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</UserControl>