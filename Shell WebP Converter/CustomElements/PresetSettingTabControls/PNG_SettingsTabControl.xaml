<UserControl x:Class="Shell_WebP_Converter.CustomElements.PresetSettingTabControls.PNG_SettingsTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:properties="clr-namespace:Shell_WebP_Converter.Resources"
             mc:Ignorable="d" 
             >
    <TabControl x:Name="SettingsTabControl" SelectedIndex="0" Grid.Column="1" VerticalAlignment="Center" Height="20" Margin="1,0,0,0">
        <TabControl.Template>
            <ControlTemplate TargetType="TabControl">
                <ContentPresenter ContentSource="SelectedContent" />
            </ControlTemplate>
        </TabControl.Template>
        <TabItem>
            <StackPanel Orientation="Horizontal">
                <ComboBox Name="CompressionComboBox" ToolTip="{x:Static properties:Resources.CompressionTooltipForPNG}" Margin="0,0,2,0" SelectedIndex="4" Width="40" Height="20" Padding="4,2,5,3">
                    <ComboBoxItem Content="0"/>
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="2"/>
                    <ComboBoxItem Content="3"/>
                    <ComboBoxItem Content="4"/>
                    <ComboBoxItem Content="5"/>
                    <ComboBoxItem Content="6"/>
                    <ComboBoxItem Content="7"/>
                    <ComboBoxItem Content="8"/>
                    <ComboBoxItem Content="9"/>
                </ComboBox>
                <ComboBox Name="FilterComboBox" ToolTip="{x:Static properties:Resources.FilterTooltipForPNG}" Margin="0,0,2,0" SelectedIndex="0" Width="40" Height="20" Padding="4,2,5,3">
                    <ComboBoxItem Content="0"/>
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="2"/>
                    <ComboBoxItem Content="3"/>
                    <ComboBoxItem Content="4"/>
                    <ComboBoxItem Content="5"/>
                </ComboBox>
            </StackPanel>
        </TabItem>
        <TabItem HorizontalAlignment="Center" >
            <Label Content="——X——" HorizontalContentAlignment="Center" HorizontalAlignment="Stretch" FontSize="12" Margin="0,-4,0,0"/>
        </TabItem>
    </TabControl>
</UserControl>